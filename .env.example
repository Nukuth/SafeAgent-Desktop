SAFEAGENT_SERVER_TOKEN=replace-with-long-random-token
SAFEAGENT_WORKER_TOKEN=replace-with-long-random-token
SAFEAGENT_CONTROL_URL=https://your-control-plane.example.com
SAFEAGENT_DEVICE_ID=local-pc-1
# Optional: set SAFEAGENT_ENV_FILE to override the default E:\agents\.env.local.
SAFEAGENT_DB_PATH=E:\agents\state\server.sqlite3
SAFEAGENT_WORKSPACE_ROOT=E:\agents
# Model base URLs and model names are configured in configs\models.json.
# Keep real API keys only in local environment variables.
SAFEAGENT_LOCAL_QWEN_API_KEY=local-no-key
SAFEAGENT_EMERGENCY_LOCAL_MODEL=false
SAFEAGENT_DEEPSEEK_API_KEY=
SAFEAGENT_CODEX_API_KEY=
SAFEAGENT_EXECUTION_MODE=dry_run
SAFEAGENT_EXECUTION_TIMEOUT_SECONDS=30
SAFEAGENT_STDOUT_LIMIT_CHARS=4000
SAFEAGENT_STDERR_LIMIT_CHARS=4000
SAFEAGENT_ENABLE_LIVE_READONLY=false
SAFEAGENT_GRAPH_RUNTIME=auto
